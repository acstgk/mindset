<div class="tech-specs">
  <div class="accordian-header">Key Features:</div>
  <div class="tech-specs--list">
    {% for feature in product.metafields.product.features.value %}
      {% case feature %}
        {% when 'Tapered Fit' %}
          <div class="tech-specs--item {{feature }}">{{ images['Tapered_Fit.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Sweat Resistant' %}
          <div class="tech-specs--item {{feature }}">{{ images['Sweat_Resistant.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Squat Proof' %}
          <div class="tech-specs--item {{feature }}">{{ images['Squat_Proof.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Shower Proof' %}
          <div class="tech-specs--item {{feature }}">{{ images['Shower_Proof.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Seamless' %}
          <div class="tech-specs--item {{feature }}">{{ images['Seamless.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Removable Pads' %}
          <div class="tech-specs--item {{feature }}">{{ images['Removable_Pads.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Reflective' %}
          <div class="tech-specs--item {{feature }}">{{ images['Reflective.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Recycled Material' %}
          <div class="tech-specs--item {{feature }}">{{ images['Recycled_Material.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Quick Drying' %}
          <div class="tech-specs--item {{feature }}">{{ images['Quick_Drying.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Muscle Fit' %}
          <div class="tech-specs--item {{feature }}">{{ images['Muscle_Fit.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Multi Stretch' %}
          <div class="tech-specs--item {{feature }}">{{ images['Multi_Stretch.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Moisture Wicking' %}
          <div class="tech-specs--item {{feature }}">{{ images['Moisture_Wicking.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'High Waisted' %}
          <div class="tech-specs--item {{feature }}">{{ images['High_Waisted.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Cropped Style' %}
          <div class="tech-specs--item {{feature }}">{{ images['Cropped_Style.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Bum Sculpting' %}
          <div class="tech-specs--item {{feature }}">{{ images['Bum_Sculpting.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Breathable' %}
          <div class="tech-specs--item {{feature }}">{{ images['Breathable.png'] | image_url: width: 112 | image_tag }}</div>
        {% else %}
          <div class="tech-specs--item {{feature }}"> <img src="https://placehold.co/62?text=IMAGE&font=oswald" alt="" height="62" width="62">{{ feature }}</div>
      {% endcase %}
    {% endfor %}
  </div>
</div>
