<div class="tech-specs">
  <div class="accordian-header">key features:</div>
  <div class="tech-specs--list">
    {% for feature in product.metafields.product.features.value %}

      {% case feature %}
        {% when 'Tapered Fit' %}
          <div class="tech-specs--item">{{ images['Tapered_Fit.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Sweat Resistant' %}
          <div class="tech-specs--item">{{ images['Sweat_Resistant.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Squat Proof' %}
          <div class="tech-specs--item">{{ images['Squat_Proof.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Shower Proof' %}
          <div class="tech-specs--item">{{ images['Shower_Proof.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Seamless' %}
          <div class="tech-specs--item">{{ images['Seamless.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Removable Pads' %}
          <div class="tech-specs--item">{{ images['Removable_Pads.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Reflective' %}
          <div class="tech-specs--item">{{ images['Reflective.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Recycled Material' %}
          <div class="tech-specs--item">{{ images['Recycled_Material.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Quick Drying' %}
          <div class="tech-specs--item">{{ images['Quick_Drying.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Muscle Fit' %}
          <div class="tech-specs--item">{{ images['Muscle_Fit.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Multi Stretch' %}
          <div class="tech-specs--item">{{ images['Multi_Stretch.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Moisture Wicking' %}
         <div class="tech-specs--item">{{ images['Moisture_Wicking.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'High Waisted' %}
          <div class="tech-specs--item">{{ images['High_Waisted.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Cropped Style' %}
          <div class="tech-specs--item">{{ images['Cropped_Style.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Bum Sculpting' %}
          <div class="tech-specs--item">{{ images['Bum_Sculpting.png'] | image_url: width: 112 | image_tag }}</div>
        {% when 'Breathable' %}
          <div class="tech-specs--item">{{ images['Breathable.png'] | image_url: width: 112 | image_tag }}</div>
        {% else %}
          <div class="tech-specs--item">{{ feature.title }}</div>
      {% endcase %}
    {% endfor %}
  </div>
</div>