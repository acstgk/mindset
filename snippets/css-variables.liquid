{% style %}
    {% comment %} FONTS {% endcomment %}
    @font-face {
      font-family: "Regular";
      src: url("{{ 'font-regular.woff2' | asset_url }}") format("woff2"), url("{{ 'font-regular.ttf' | asset_url }}") format("truetype");
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: "Regular";
      src: url("{{ 'font-regular-bold.woff2' | asset_url }}") format("woff2"),url("{{ 'font-regular-bold.woff' | asset_url }}") format("woff");
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: "Condensed";
      font-style: normal;
      src: url("{{ 'font-condensed.woff2' | asset_url }}") format("woff2"), url("{{  'font-condensed.ttf' | asset_url }}") format("truetype");
      font-display: swap;
      size-adjust: 125%;
    }

    @font-face {
      font-family: "Signature";
      font-style: normal;
      src: url("{{ 'font-signature.woff2' | asset_url }}") format("woff2"), url("{{ 'font-signature.otf' | asset_url }}"), url("{{  'font-signature.ttf' | asset_url }}") format("truetype");
      font-display: swap;
      size-adjust: 200%;
    }

    @font-face {
      font-family: 'Octin';
      src: url("{{ 'Octin_College_Bold.ttf' | file_url }}") format('truetype');
    }

     @font-face {
      font-family: 'Baskerville';
      font-style: normal;
      src: url("{{ 'font-baskerville.woff2' | asset_url }}") format("woff2"), url("{{ 'font-baskerville.ttf' | asset_url }}") format("truetype");
      font-display: swap;
      size-adjust: 90%;
    }

    @font-face {
      font-family: 'regular-fallback';
      src: local(Verdana);
      size-adjust: 90%;
      ascent-override: 114%;
      descent-override: 52%;
      line-gap-override: 0%;
      font-display: fallback;
    }

    @font-face {
      font-family: 'condensed-fallback';
      src: local(Impact);
      size-adjust: 100%;
      ascent-override: 126%;
      descent-override: 48%;
      line-gap-override: normal;
      font-weight: 400;
      font-display: fallback;
    }


    {{ settings.heading_font | font_face: font_display: 'fallback' }}
    {{ settings.text_font | font_face: font_display: 'fallback' }}

    {{ text_font_bold | font_face: font_display: 'fallback' }}
    {{ text_font_italic | font_face: font_display: 'fallback' }}
    {{ text_font_bold_italic | font_face: font_display: 'fallback' }}

    :root {

      --emphasis-heading-font-family : condensed, condensed-fallback, san-serif;
      --emphasis-heading-font-weight : 400;
      --emphasis-heading-font-style  : normal;

      --heading-font-family : regular, regular-fallback, sans-serif;
      --heading-font-weight : 700;
      --heading-font-style  : normal;

      --text-font-family : regular, regular-fallback, sans-serif;
      --text-font-weight : 400;
      --text-font-style  : normal;

      --signature-text-font-family : signature, regular, regular-fallback, sans-serif;
      --octin-font-family : octin, condensed, condensed-fallback, Impact, sans-serif;
      --baskerville-font-family : baskerville, "Times New Roman",serif;

      /* --txt-sm: clamp(0.67rem, 0.05vi + 0.7rem, 0.76rem);
      --txt-p: clamp(0.8rem, 0.09vi + 0.78rem, 0.86rem);
      --txt-h4: clamp(1rem, 0.22vi + 0.94rem, 1.14rem);
      --txt-h3: clamp(1.25rem, 0.43vi + 1.13rem, 1.52rem);
      --txt-h2: clamp(1.56rem, 0.73vi + 1.36rem, 2.03rem);
      --txt-h1: clamp(1.95rem, 1.18vi + 1.63rem, 2.71rem);
      --txt-xl: clamp(2.5rem, 1.83vi + 2rem, 3.75rem);
      --txt-xxl: clamp(3.25rem, 2.2vi + 2.9rem, 4.6rem); */

--txt-sm: clamp(0.65rem, 0.16vi + 0.61rem, 0.81rem);
--txt-p: clamp(0.81rem, 0.3vi + 0.74rem, 1rem);
--txt-h4: clamp(0.92rem, 0.4vi + 0.81rem, 1.225rem);
--txt-h3: clamp(1.02rem, 0.51vi + 0.89rem, 1.33rem);
--txt-h2: clamp(1.27rem, 0.81vi + 1.07rem, 1.78rem);
--txt-h1: clamp(1.59rem, 1.25vi + 1.27rem, 2.37rem);
--txt-xl: clamp(2.48rem, 2.77vi + 1.79rem, 4.21rem);
--txt-xxl: clamp(3.1rem, 4.02vi + 2.1rem, 5.61rem);




      --letter-spacing: 0.075em;
      --radius: 2px;
      --aspect-ratio: 0.722;
    }


    {% comment %} COLOURS {% endcomment %}

    :root {
    --c-white: #fff;
    --c-off-white: hsla(27, 16%, 96%, 1.00);
    --c-black: #1f1e1f;
    --c-light-grey: #d3d3d3;
    --c-grey: #949597;
    --c-dark-grey: #38363b;
    --c-error: #AE352E;
    --c-warning: #ef6d02;
    --c-success: #357E16;
    --c-info: #33658A;
    --c-sale: {{ settings.sale_colour }};
    --c-shadow: rgb(20 20 20 / 0.2);
    --c-boys: #39cef6;
    --c-girls: #ff98ca;

  }

   {% comment %} STRUCTURE {% endcomment %}

   :root {
    --max-width: min(90vw, 1400px);
    --bezier: cubic-bezier(.17,.67,.22,1.2);
   }

   ul.dropdown_col-links a.desktop--highlighted--menu-alt,
   .side_menu-menu ul li a.mobile--highlighted--menu-alt  {
      background-color: {{ settings.highlighted-button_color-alt }};
      color: {{ settings.highlighted-text_color-alt }};
    }

    ul.dropdown_col-links a.desktop--highlighted--menu,
    .side_menu-menu ul li a.mobile--highlighted--menu  {
      background-color: {{ settings.highlighted-button_color }};
      color: {{ settings.highlighted-text_color }};
    }

    .side_menu-menu ul li a.mobile--highlighted--menu-alt,
    .side_menu-menu ul li a.mobile--highlighted--menu {
      margin: 0 -20px;
      padding-left: 20px;
    }
    .side_menu-menu ul li:nth-child(n+2) a.mobile--highlighted--menu-alt,
    .side_menu-menu ul li:nth-child(n+2) a.mobile--highlighted--menu {
      padding-top: 1.2rem;
      margin-top: -0.8rem;
    }
{% endstyle %}
