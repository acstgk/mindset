{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_type = 'website'
  assign og_url = canonical_url
  assign og_site_name = shop.name

  if request.page_type == 'product'
    assign og_title = product.title | strip_html
    assign og_type = 'product'
    if product.featured_image
      assign og_image = product.featured_image | image_url: width: '1200' | prepend: 'https:'
      assign og_image_secure_url = product.featured_image | image_url: width: '1200' | prepend: 'https:'
      assign og_image_width = product.featured_image.width
      assign og_image_height = product.featured_image.height
      assign og_image_alt = product.featured_image.alt | default: product.title
    endif
  elsif request.page_type == 'article'
    assign og_title = article.title | strip_html
    assign og_type = 'article'
    if article.image
      assign og_image = article.image | image_url: width: '1200' | prepend: 'https:'
      assign og_image_secure_url = article.image | image_url: width: '1200' | prepend: 'https:'
      assign og_image_width = article.image.width
      assign og_image_height = article.image.height
      assign og_image_alt = article.image.alt | default: article.title
    endif
  elsif request.page_type == 'collection'
    assign og_title = collection.title | strip_html
    assign og_type = 'website'
    assign collection_image = collection.image | default: collection.products.first.featured_image | image_url: width: '1200' | prepend: 'https:'
    if collection_image
      assign og_image = collection_image
      assign og_image_secure_url = collection_image
      assign og_image_width = collection_image.width
      assign og_image_height = collection_image.height
      assign og_image_alt = collection_image.alt | default: collection.title
    endif
  elsif request.page_type == 'password'
    assign og_title = shop.name
    assign og_url = shop.url
    assign og_description = shop.description | default: shop.name
  endif

  # Twitter Card logic
  assign twitter_card = 'summary_large_image'
  assign twitter_title = og_title
  assign twitter_description = og_description | strip_html | truncatewords: 140, ''
  assign twitter_image = ''

  if request.page_type == 'product'
    assign twitter_image = product.featured_image | image_url: width: '1200' | prepend: 'https:'
  elsif request.page_type == 'article'
    if article.image
      assign twitter_image = article.image | image_url: width: '1200', height: '628', crop: 'center' | prepend: 'https:'
    endif
  elsif request.page_type == 'collection'
    if collection_image
      assign twitter_image = collection_image
    endif
  endif
-%}

<!-- Open Graph Meta Tags -->
<meta property="og:site_name" content="{{ og_site_name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if og_image -%}
  <meta property="og:image" content="{{ og_image }}">
  <meta property="og:image:secure_url" content="{{ og_image_secure_url }}">
  <meta property="og:image:width" content="{{ og_image_width }}">
  <meta property="og:image:height" content="{{ og_image_height }}">
  {%- if og_image_alt -%}
    <meta property="og:image:alt" content="{{ og_image_alt | escape }}">
  {%- endif -%}
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="product:price:amount" content="{{ product.selected_or_first_available_variant.price | money_without_currency | strip_html | escape }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  <meta property="product:availability" content="{% if product.available %}instock{% else %}oos{% endif %}">
{%- endif -%}

<!-- Twitter Card Meta Tags -->
<meta name="twitter:card" content="{{ twitter_card }}">
<meta name="twitter:title" content="{{ twitter_title | escape }}">
<meta name="twitter:description" content="{{ twitter_description | escape }}">
{%- if twitter_image != blank -%}
  <meta name="twitter:image" content="{{ twitter_image }}">
{%- endif -%}
