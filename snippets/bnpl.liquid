<bnpl-options class=" ge-hide-display-none ge-hide">
  <div class="bnpl-placement">
    {{ 'klarna' | payment_type_svg_tag: class: 'icon icon--full-color' }}
    <span>
      {% if price >= 3000 %}
        or make 3 interest-free payments of <strong>{{ price | divided_by: 3 | money_without_trailing_zeros }}</strong> with Klarna.
        <br>
      {% else %}
        pay in 30 days with Klarna. <br>
      {% endif %}
      <a href="/pages/klarna-terms-conditions" class="klarna-link">Learn More</a>
    </span>
  </div>
  <div class="bnpl-placement">
    {{ 'afterpay' | payment_type_svg_tag: class: 'icon icon--full-color' }}
    <span>
      or make 4 interest-free payments of <strong>{{ price | divided_by: 4 | money_without_trailing_zeros }}</strong> with ClearPay.
      <br>
      <a href="/pages/clearpay-terms-conditions" class="clearpay-link">Learn More</a>
    </span>
  </div>
</bnpl-options>

{% style %}
  bnpl-options {
    display: flex;
    flex-flow: column;
    gap: 0.5em;
    margin-block: 1em;
    border-top: 1px solid var(--c-grey);
    padding-top: 1em;
  }
  .bnpl-placement,
  .bnpl-placement a {
    font-size: var(--txt-sm) !important;
    display: flex;
    gap: 1em;
    align-items: center;
  }

  .bnpl-placement a {
    gap: 0.2em;
  }

  .bnpl-modal {
    position: absolute;
    background-color: var(--c-white);
    inset: 0;
    margin: auto;
    width: min(100vw, 1270px);
    max-height: min(100vh, 950px);
    z-index: 11;
    overflow-y: auto;
    padding: 3rem;
    &.fade-in.active {
      height: fit-content;
    }
  }

  button.modal-close {
    position: absolute;
    inset: 3rem 3rem auto auto;
  }
{% endstyle %}
