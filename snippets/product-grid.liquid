  <infinite-scroll class="max-width">
    {%- for product in product_list -%}
      {% assign lazyload = 'lazy' %}
      {% if forloop.index0 < 5 %}
        {% assign lazyload = 'eager' %}
      {% endif %}
      {% if product.object_type == 'product' %}
        {% comment %} ---- Product Cards ---- {% endcomment %}
        {%- render 'product-card', product: product, loading: lazyload -%}
      {% endif %}
    {%- endfor -%}
  </infinite-scroll>