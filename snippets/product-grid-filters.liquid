<link rel="stylesheet" href="{{ 'filters.min.css' | asset_url }}">

<filters-menu-bar class="accent-bg">
  {% comment %} Mobile Filters Button {% endcomment %}
  {% comment %} Wrapper {% endcomment %}
  <div class="max-width inline-flex">
    <div class="column-controls" data-grid="grid">
      <span>Grid Size:</span>
      <button class="grid-control--down" aria-label="change grid size">{% render 'icon', icon: 'smaller' %}</button>
      <button class="grid-control--up" aria-label="change grid size">{% render 'icon', icon: 'bigger', class: 'rotate180' %}</button>
    </div>

    <button class="mobile-filter-button drawer-button" data-target="productFilters" aria-label="Open mobile filters">{% render 'icon', icon: 'filters' %} Filters</button>

    <slide-drawer aria-hidden="true" id="productFilters" data-side="right">
      <form id="filter-form">
        {% comment %} Mobile Filters {% endcomment %}
        <div class="filterby-container">
          <small>
            <span class="product-count">{{ collection.products_count }}</span> matching products
          </small>
          <br>
          <span> Filter by:</span>
          {% assign active_count = 0 %}

          <content-accordian>
            {%- for filter in group.filters -%}
              {% if request.path contains '/mens' or request.path contains '/womens' or filter.values.size < 3 %}
                {% assign is_gendered = true %}
              {% endif %}
              {% if filter.values.size > 1 or filter.type == 'price_range' %}
                {% unless is_gendered and filter.label == 'Gender' %}
                  <div class="accordian-items filter_item filter_item-{{- filter.label | handle -}} ">
                    <div class="accordian-header filter_item-name item-{{- filter.label | handle -}}" data-active-count="{{ filter.active_values.size | default: 0}}">
                      <div class="filter_item-title">
                        {% if filter.label == 'Sale' and request.path contains 'sale' %}
                          Discount
                        {% else %}
                          {{ filter.label }}
                        {% endif %}
                        {%- if filter.active_values.size > 0 -%}
                          {% assign active_count = active_count | plus: 1 %}
                          <i
                            >({{ filter.active_values.size -}}
                            <span class="pluralize"> {{ filter.active_values.size | pluralize: 'filter', 'filters' }} active</span>)</i
                          >
                        {%- endif -%}
                      </div>
                    </div>
                    {%- case filter.type -%}
                      {%- when 'list' -%}
                        <div id="filter-{{ filter.label | handle }}" class="filter_item-values accordian-content no-animation">
                          <p class="mob-hide">{{ filter.label }}</p>
                          <ul>
                            {% comment %} sort the product types by quantity {% endcomment %}
                            {% assign sorted_values = filter.values %}
                            {% if filter.label == 'Product Type' %}
                              {% assign sorted_values = filter.values | sort: 'count' | reverse %}
                            {% else %}
                              {% assign sorted_values = filter.values | sort: 'label' %}
                            {% endif %}
                            {%- for filter_value in sorted_values -%}
                              {% assign order = '-1' %}
                              {% assign kids_sizes = '3-45-67-89-1011-1213-1415' %}
                              {% assign is_kids = false %}
                              {% if kids_sizes contains filter_value.label and filter_value.label contains '-' or filter_value.label == '15' %}
                                {% assign is_kids = true %}
                                {% assign order = '1' %}
                              {% endif %}

                              <li
                                class="filter_value-checkbox"
                                {% if filter_value.label == 'hidden' %}
                                  hidden
                                {% endif %}
                                {% if filter_value.label contains 'up to 40% off' or is_kids %}
                                  style="order:{{order}};"
                                {% endif %}
                              >
                                <input
                                  type="checkbox"
                                  name="{{ filter_value.param_name }}"
                                  value="{{ filter_value.value }}"
                                  id="Filter-{{ filter_value.param_name }}-{{ forloop.index }}"
                                  {% if filter_value.active -%}
                                    checked
                                  {%- endif %}
                                  {% if filter_value.count == 0 and filter_value.active == false -%}
                                    disabled
                                  {%- endif %}
                                >
                                <label for="Filter-{{ filter_value.param_name }}-{{ forloop.index }}" class="filter_value-label {% if filter_value.count == 0 and filter_value.active == false -%}disabled-label{% endif %}">
                                  {%- case filter.presentation -%}
                                    {%- when 'swatch' -%}
                                      <div class="swatch" style="background: {{ filter_value.swatch.color }};border-color:{{ filter_value.swatch.color | color_darken: 15 }}"></div>
                                    {%- when 'image' -%}
                                      {{ filter_value.swatch.image | image_url: width: 15 | image_tag: alt: filter_value.swatch.image.alt, class: 'swatch' }}
                                  {%- endcase -%}
                                  {{ filter_value.label -}}
                                  {%- if is_kids %} years{% endif %} ({{ filter_value.count }})
                                </label>
                              </li>
                            {%- endfor -%}
                          </ul>
                          <input type="submit" value="Apply" class="filter-apply button button-secondary">
                        </div>
                      {%- when 'price_range' -%}
                        <div id="filter-{{ filter.label | handle }}" class="filter_item-values accordian-content no-animation filter_item-price-range">
                          {% liquid
                            if filter.min_value.value
                              assign min_value = filter.min_value.value | money_without_currency | floor
                              assign active_count = active_count | plus: 1
                            else
                              assign min_value = ''
                            endif
                            if filter.max_value.value
                              assign max_value = filter.max_value.value | money_without_currency | floor
                              assign active_count = active_count | plus: 1
                            else
                              assign max_value = ''
                            endif
                          %}
                          <p class="mob-hide">{{ filter.label }}</p>
                          <div class="price_range-sliders">
                            <!-- from slider -->
                            <input id="fromSlider" type="range" min="0" step="1" max="{{ filter.range_max | money_without_currency | floor }}" value="{% if min_value != '' %}{{ min_value }}{% else %}0{% endif %}">
                            <!-- to slider -->
                            <input
                              id="toSlider"
                              type="range"
                              min="0"
                              step="1"
                              max="{{ filter.range_max | money_without_currency | floor }}"
                              value="{% if max_value != '' %}{{ max_value }}{% else %}{{ filter.range_max | money_without_currency | floor }}{% endif %}"
                            >
                          </div>
                          <div class="price-divisions">
                            <div class="price-low">{{ cart.currency.symbol }}0</div>
                            <div class="price-mid">
                              {{ cart.currency.symbol -}}
                              {{- filter.range_max | divided_by: 2 | money_without_currency }}
                            </div>
                            <div class="price-high">
                              {{ cart.currency.symbol -}}
                              {{- filter.range_max | money_without_currency | floor }}
                            </div>
                          </div>
                          <div class="price-selector">
                            <!-- from input -->
                            <div class="filter-group-display__price-range-from">
                              <label for="Filter-{{ filter.min_value.param_name }}">From</label>
                              <div class="price-input">
                                <span class="price-input-currency">{{ cart.currency.symbol }}</span>
                                <input
                                  name="{{ filter.min_value.param_name }}"
                                  id="Filter-{{ filter.min_value.param_name }}"
                                  class="fromInput button button-secondary"
                                  value="{{ min_value }}"
                                  type="number"
                                  placeholder="0"
                                  min="0"
                                  step="1"
                                  max="{{ filter.range_max | money_without_currency | floor }}"
                                >
                              </div>
                            </div>
                            <!-- to input -->
                            <div class="filter-group-display__price-range-to">
                              <label for="Filter-{{ filter.max_value.param_name }}">To</label>
                              <div class="price-input">
                                <span class="price-input-currency">{{ cart.currency.symbol }}</span>
                                <input
                                  name="{{ filter.max_value.param_name }}"
                                  id="Filter-{{ filter.max_value.param_name }}"
                                  class="toInput button button-secondary"
                                  value="{{ max_value }}"
                                  type="number"
                                  placeholder="{{ filter.range_max | money_without_currency | floor }}"
                                  min="0"
                                  step="1"
                                  max="{{ filter.range_max | money_without_currency | floor }}"
                                >
                              </div>
                            </div>
                          </div>
                          {% if template.name == 'search' %}
                            <input hidden value="{{ search.terms }}" name="q">
                          {% endif %}
                          <input hidden value="1" name="page">
                          <input type="submit" value="Apply" class="filter-apply button button-secondary">
                        </div>
                    {%- endcase -%}
                  </div>
                {% endunless %}
              {% endif %}
            {% endfor %}
          </content-accordian>
        </div>
        {% comment %} Sort By Options {% endcomment %}
        <div class="sortby-container inline-flex">
          <label for="sort_by" style="color:var(--c-dark-grey);flex:1 0 auto">Sort by:</label>
          <select name="sort_by" id="SortBy">
            {%- for option in group.sort_options -%}
              {% unless option.name contains 'Date' %}
                <option
                  value="{{ option.value | escape }}"
                  {% if option.value == group.sort_by %}
                    selected="selected"
                  {% endif %}
                >
                  {{ option.name | escape }}
                </option>
              {% endunless %}
            {%- endfor -%}
          </select>
        </div>
      </form>
    </slide-drawer>
  </div>
</filters-menu-bar>
