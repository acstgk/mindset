<predictive-search id="search" aria-hidden="true">
  <form class="max-width" id="search_form" action="{{ routes.search_url }}">
    <button type="submit" value="Search" aria-label="submit search term">{% render 'icon', icon: 'search' %}</button>
    <input type="hidden" name="type" value="product">
    <input
      id="Search"
      class="search_form-terms-input"
      type="search"
      name="q"
      value=""
      placeholder="Search..."
      role="combobox"
      aria-expanded="false"
      aria-owns="predictive-search-results"
      aria-controls="predictive-search-results"
      autofocus
      required
    >
      <button class="search_form-close" aria-label="close search">{% render 'icon', icon: 'plus', class: 'rotate45' %}</button>
  </form>
</predictive-search>
