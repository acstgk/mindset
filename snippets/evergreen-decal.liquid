{% if product.tags contains 'impactpro' %}
  <img class="{{ class }}" src="https://cdn.shopify.com/s/files/1/1659/8997/files/Impact_Pro.png?v=1742477681" width="960" height="835" alt="ImpactPRO Combat Fabric">
{% elsif product.tags contains 'bundle' and localization.country.iso_code == "GB" %}
  <img class="{{ class }}" src="https://cdn.shopify.com/s/files/1/1659/8997/files/Decal_Decal_-_Save_with_Bundle.png?v=1761311619" width="960" height="835" alt="Bundle this product and save">
{% elsif product.tags contains 'mini' %}
  <img class="{{ class }}" src="https://cdn.shopify.com/s/files/1/1659/8997/files/Decal_Decal_-_Mini_Me_Available.png?v=1761311619" width="960" height="835" alt="Also available in kid's sizing for mini me styling">
{% endif %}
