{% assign mapped_title = title | replace: 'One Size', 'Add to Bag' | replace: ".00", "" %}

{% if localization.market.handle != 'gb' %}
  {% assign mapping = "" %}

  {% if product.tags contains 'Women' or product.tags contains 'Womens' or product.tags contains 'women' or product.tags contains 'womens' %}
    {% comment %} Women's Mapping: UK:EU:US {% endcomment %}
    {% assign mapping = "6:34:2,8:36:4,10:38:6,12:40:8,14:42:10,16:44:12,18:46:14,20:48:16,6-8:34-36:2-4,10-12:38-40:6-8,14-16:42-44:10-12" %}
  {% else %}
    {% comment %} Men's/Unisex Mapping: UK:EU:US {% endcomment %}
    {% assign mapping = "XS:44:34,S:46:36,M:48:38,L:50:40,XL:52:42,XXL:54:44,XXXL:56:46" %}
  {% endif %}

  {% assign mapping_items = mapping | split: "," %}
  {% for item in mapping_items %}
    {% assign parts = item | split: ":" %}
    {% if parts[0] == title %}
      {% if localization.country.continent == 'Europe' %}
        {% assign mapped_title = parts[1] %}
        {% assign region = "EU" %}
    {% elsif localization.country.continent == 'North America' %}
        {% assign mapped_title = parts[2] %}
        {% assign region = "US" %}
      {% endif %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{{-region-}}{{- mapped_title -}}