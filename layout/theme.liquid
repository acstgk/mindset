    {% render 'adroll' %}
    <script>
      function iwishATB(button) {
        var Title = button.closest('.iwishItem').getAttribute('data-title');
        var Price = button.closest('.iwishItem').getAttribute('data-price') / 100;
        var Gender = button.closest('.iwishItem').getAttribute('data-gender');
        var selectedVariant = button.previousElementSibling.firstElementChild.value;

        document.getElementById('close-cart-drawer').click(),
          CartJS.addItem(selectedVariant),
          setTimeout(function () {
            document.documentElement.dispatchEvent(
              new CustomEvent('cart:refresh', {
                bubbles: true,
              })
            );
            refreshcart();
            document.getElementById('drawerbtn').click();
          }, 1e3);

        gtag('event', 'atc_wishlist', {
          title: Title,
          value: Price,
          gender: Gender,
        });
      }
    </script>
  </body>

