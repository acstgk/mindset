    <script>
      (function () {
        window.onpageshow = function () {
          if (window.theme.showPageTransition) {
            var pageTransition = document.querySelector('.PageTransition');

            if (pageTransition) {
              pageTransition.style.visibility = 'visible';
              pageTransition.style.opacity = '0';
            }
          }

          // When the page is loaded from the cache, we have to reload the cart content
          document.documentElement.dispatchEvent(
            new CustomEvent('cart:refresh', {
              bubbles: true,
            })
          );
        };
      })();
    </script>

    <script>
      var glegem =
        window['glegem'] ||
        function () {
          (window['glegem'].q = window['glegem'].q || []).push(arguments);
        };

      glegem('OnCheckoutStepLoaded', function (data) {
        switch (data.StepId) {
          case data.Steps.LOADED:
            break;
          case data.Steps.CONFIRMATION:
            if (data.IsSuccess) {
              (function (window) {
                try {
                  var productsArray = [];
                  for (let temp = 0; temp < data.details.products.length; temp++) {
                    let tempProducts = {};
                    tempProducts.sku = data.details.products[temp].sku;
                    tempProducts.title = data.details.products[temp].name;
                    tempProducts.price = data.details.products[temp].customerPriceInMerchantCurrency;
                    tempProducts.quantity = data.details.products[temp].quantity;
                    tempProducts.variantid = data.details.products[temp].productGroupCode;
                    productsArray.push(tempProducts);
                  }
                  var discountAmount = 0;
                  for (let temp = 0; temp < data.details.discounts.length; temp++) {
                    if (
                      data.details.discounts[temp].couponCode != '' &&
                      data.details.discounts[temp].discountTypeId == 1
                    ) {
                      discountAmount = data.details.discounts[temp].customerPriceInMerchantCurrency;
                    }
                  }
                  var saleGoalObject = {
                    transactionId: data.OrderId ?? '',
                    revenue: data.details.totalProductsPrice ?? '',
                    subtotal: data.details.totalProductsPrice ?? '',
                    discount: discountAmount ?? '',
                    products: productsArray ?? '',
                    currency: data.details.currency ?? '',
                  };

                  var saleGoalString = JSON.stringify(saleGoalObject);
                  window.fospha = window.fospha || [];
                  fospha('send', 'event', {
                    eventCategory: 'goal',
                    eventCatLabel: 'goal',
                    eventAction: 'achieved',
                    eventItemId: 'sale',
                    eventLabel: 'sale',
                    eventText: saleGoalString,
                  });
                } catch (e) {
                  console.log(e);
                }
              })(window);
            }
            break;
        }
      });

      var variantStock = {};
    </script>

    {% render 'globale-js' %}

    <link rel="stylesheet" href="{{ 'global.min.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'splide-core.min.css' | asset_url }}">

    <script>
      //old gtag used by fospha and taggstar
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-PT4PRKB');

      // Gtag
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        functionality_storage: 'denied',
