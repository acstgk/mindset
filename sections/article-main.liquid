<link rel="stylesheet" href="{{ 'articles.min.css' | asset_url }}">

{% if article.image %}
  <style>
    .article-hero::before {
      background-image: url('{{ article.image | image_url: width: 1400 }}');
    }
  </style>
  <div class="article-hero"></div>

{% endif %}

<div class="article-wrapper rtf">
  <div class="article-meta">
    <div class="article-details">
      {%- if article.metafields.article.event_location.value -%}
        <b>Event date:</b> {{ article.metafields.article.event_date.value | date: '%B %d, %Y' }}
        <br>
        <b>Event location:</b> {{ article.metafields.article.event_location.value }}
      {% elsif article.metafields.article.event_date.value %}
        <b>Event date:</b> {{ article.metafields.article.event_date.value | date: '%B %d, %Y' }}
      {% else %}
        <b>Article date:</b> {{ article.published_at | date: '%B %d, %Y' | default: '<i>publish date TBC</i>' }}
      {%- endif -%}
    </div>
    {% if blog.next_article or blog.previous_article %}
      <div class="article-nav">
        {% if blog.next_article %}
          <a href="{{ blog.next_article.url }}" class="article-nav__item pre_render">{% render 'icon', icon: 'arrow', class: 'rotate180' %}</a>
        {% endif %}
        {% if blog.previous_article %}
          <a href="{{ blog.previous_article.url }}" class="article-nav__item pre_render">{% render 'icon', icon: 'arrow' %}</a>
        {% endif %}
      </div>
    {% endif %}
  </div>
  <h1>{{ article.title }}</h1>

  {% if article.metafields.custom.video.value %}
    {% assign video = article.metafields.custom.video.value %}
    {% assign poster = '/cdn/shop/' | append: video.preview_image | replace: '.jpg', '_grande.jpg' %}
    {% assign video_tag = article.metafields.custom.video.value | video_tag: controls: true, poster: poster %}
    {% assign split_content = article.content | replace: 'insert-video-here', video_tag %}
    {{ split_content }}
  {% else %}
    {{ article.content }}
  {% endif %}
</div>

  <script>
    (function() {
      const header = document.querySelector('.article-hero');
      if (!header) return;

      let currentScroll = window.scrollY;
      let targetScroll = window.scrollY;
      const ease = 0.1;
      let isRunning = false;

      function update() {
        isRunning = true;
        const diff = targetScroll - currentScroll;
        if (Math.abs(diff) > 0.1) {
          currentScroll += diff * ease;
          header.style.setProperty('--scroll', currentScroll.toFixed(2));
          requestAnimationFrame(update);
        } else {
          currentScroll = targetScroll;
          header.style.setProperty('--scroll', currentScroll.toFixed(2));
          isRunning = false;
        }
      }

      window.addEventListener('scroll', () => {
        targetScroll = window.scrollY;
        if (!isRunning) {
          requestAnimationFrame(update);
        }
      }, { passive: true });

      // Initial set
      header.style.setProperty('--scroll', currentScroll.toFixed(2));
    })();
  </script>
{% schema %}
{
  "name": "Article Main",
  "class": "section--article-main",
  "settings": []
}
{% endschema %}
