<div class="PageContent max-width content-mosaic--wrapper">
  {% for block in section.blocks %}
    {% if block.type == 'grid-item' %}
    <div
      class="content-mosaic--item {% if block.settings.content_placement == 'overlay' %}item-overlay{% elsif block.settings.content_placement == '50' %}item-50{% endif %} {% if block.settings.grid_column_span < block.settings.grid_row_span %}stack-content{% endif %}"
      style="--c-span:{{ block.settings.grid_column_span }};--r-span:{{ block.settings.grid_row_span }};--background:{{ block.settings.bg_color }};--txt-color:{{ block.settings.txt_color }};"
    >
      {% if block.settings.img %}
        {{ block.settings.img | image_url: width: '1200' | image_tag: width: '1200', alt: block.settings.img_alt, class: block.settings.img_transition }}
      {% else %}
        <img src="https://placehold.co/400?text=IMAGE&font=oswald" alt="" height="400" width="400" class="{{ block.settings.img_transition  }}">
      {% endif %}

      {% unless block.settings.content_placement == 'hidden' %}
        <div class="content-mosaic--content">
          <h2 class="emphasis {{ block.settings.heading_size }}">{{ block.settings.title }}</h2>
          {{ block.settings.text }}
          {% if block.settings.cta_text != '' %}
            <a class="button button-primary" style="max-width: 100%;--btn-bg:{{ block.settings.btn_color }}" href="{{ block.settings.cta_url | default: '#' }}">{{ block.settings.cta_text }}</a>
          {% endif %}
          {% if block.settings.cta_text2 != '' %}
            <a class="button button-primary" style="max-width: 100%;--btn-bg:{{ block.settings.btn_color2 }}" href="{{ block.settings.cta_url2 | default: '#' }}">{{ block.settings.cta_text2 }}</a>
          {% endif %}
        </div>
      {% endunless %}

      {% case block.settings.flag %}
        {% when 'best' %}
          {% assign flag_colour = 'var(--c-black)' %}
          {% assign flag_copy = 'Fan Favourite' %}
          {% assign flag_icon = 'star' %}
        {% when 'soon' %}
          {% assign flag_colour = 'var(--c-info)' %}
          {% assign flag_copy = 'Coming Soon' %}
          {% assign flag_icon = 'bell' %}
        {% when 'limited' %}
          {% assign flag_colour = '#701673ff' %}
          {% assign flag_copy = 'Limited Edition' %}
          {% assign flag_icon = 'diamond' %}
        {% when 'legacy' %}
          {% assign flag_colour = '#015b34ff' %}
          {% assign flag_copy = 'From the Archive' %}
          {% assign flag_icon = 'award' %}
      {% endcase %}

      {% unless block.settings.flag == '' %}
        <div class="flag" style="--colour:{{ flag_colour }};">
          {% render 'icon', icon: flag_icon %}
          <span>{{ flag_copy }}</span>
        </div>
      {% endunless %}
    </div>
    {% elsif block.type == 'spacer' %}
    <div class="spacer"></div>
  {% endif %}
  {% endfor %}
</div>
<style>
  .content-mosaic--wrapper {
    display: grid;
    height: auto;
    --grid-columns: 2;
    grid-template-rows: repeat(auto-fill, 1fr);
    grid-template-columns: repeat(var(--grid-columns), 1fr);
    gap: 1.5rem;
    margin: 0.75rem auto;
    align-items: stretch;

     & .spacer {
        grid-column: 1 / -1;
        height:1px;
        background-color: var(--c-black);
        margin: 1rem 0;
      }
  }

  .content-mosaic--item {
    --c-span: 1;
    --r-span: 1;
    --actual-c-span: min(var(--c-span), var(--grid-columns));
    --background: #f6f6f6;
    background-color: var(--background);
    width: 100%;
    height: 100%;
    grid-column: span var(--actual-c-span);
    grid-row: span var(--r-span);
    position: relative;
    overflow: hidden;
    color: var(--txt-color) !important;

    & h2 {
      margin: 0;
      text-align: left;
    }

    & .content-mosaic--content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1lh;
      padding: max(2rem, 2vh) max(1rem, 1vw);
    }

    &.item-overlay {
      display: grid;
      &>* {
        grid-area: 1 / 1 / 2 / 2;
        text-align: left;
      }
      & img {
        height:100%;
      }

      & .content-mosaic--content {
        width: 100%;
        height: 100%;
        text-shadow: 0 0 3px var(--c-dark-grey);
        backdrop-filter: brightness(0.8);
        transition: backdrop-filter 0.2s ease-in-out;
        &:hover {
          backdrop-filter: brightness(1);
        }
      }
    }

    &.item-50 {
      display: flex;
      flex-wrap: wrap;

      & img {
        width: 100%;
        flex: 1 1 50%;
        background-color: var(--background);

        &.img-mask {
          mask-image: linear-gradient(180deg, rgba(59, 59, 59, 100) 1%, rgba(52, 52, 52, 100) 70%, rgba(52, 52, 52, 0) 98%);
        }
      }

      & .content-mosaic--content {
        flex: 1 1 max-content;
      }
    }

    & .flag {
      position: absolute;
      left: -2px;
      top: min(30px, 5vw);
      display: flex;
      gap: 1ch;
      width: max-content;
      box-shadow: 0 0 5px var(--c-shadow);

      & svg {
        height: 1rem;
      }

      & span {
        width: max-content;
        display: block;
      }
    }

    & img {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
    }
  }

  @media screen and (min-width: 768px) {
    .content-mosaic--wrapper {
      --grid-columns: 4;
    }

    .content-mosaic--item {
      aspect-ratio: var(--actual-c-span) / var(--r-span);

      & .content-mosaic--content {
        padding: max(1rem, 1vh) max(3rem, 3vw);
        height: 100%;
      }

      & img {
        height: 100%;
        aspect-ratio: var(--actual-c-span) / var(--r-span);
      }

      &.item-50 {
        &>* {
          max-width: 50%;
        }

        & img.img-mask {
          mask-image: linear-gradient(90deg, rgba(59, 59, 59, 100) 1%, rgba(52, 52, 52, 100) 70%, rgba(52, 52, 52, 0) 98%);
        }

        &.stack-content {
          &>* {
            max-width: 100%;
            height: auto;
          }
          & img {
            max-height: 50%;
            &.img-mask {
              mask-image: linear-gradient(180deg, rgba(59, 59, 59, 100) 1%, rgba(52, 52, 52, 100) 50%, rgba(52, 52, 52, 0) 97%);
            }
          }
        }
      }
    }
  }

  @media screen and (max-width: 500px) {
    .content-mosaic--item:has(.content-mosaic--content) {
      grid-column: span 2 !important;
    }
  }

</style>
