<h1>{{ page.title }}</h1>

<div class="contents-grid">
  {% for block in section.blocks %}
    <a rel="canonical" href="{{ block.settings.url }}" class="contents-grid--card accent-bg">
      {{ block.settings.image | image_url: width: '75px' | image_tag }}
      <h2 class="h4">{{ block.settings.heading }}</h2>
    </a>
  {% endfor %}
</div>

<style>
  .contents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(135px, 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }

  .contents-grid--card {
    aspect-ratio: 1;
    display: flex;
    flex-flow: column;
    justify-content: center;
    align-items: center;
    padding: 1.5rem;
    margin: 0;
    transition: background-color 0.2s ease;
  }

  .contents-grid--card:hover {
    background-color: color-mix(in lab, var(--c-off-white), black 10%);
  }

  .contents-grid--card:hover img {
    scale: 1.1;
  }

  .contents-grid--card h2 {
    text-transform: none;
    color: var(--c-dark-grey);
  }

  .contents-grid--card img {
    width: min(35%, 100px);
    transition: scale 0.2s ease;
    opacity: 0.75;
  }

  @media screen and (width > 600px) {
  .contents-grid {
    grid-template-columns: repeat(auto-fit, minmax(225px, 1fr));
  }
  @media screen and (width > 900px) {
  .contents-grid {
    grid-template-columns: repeat(auto-fit, minmax(275px, 1fr));
  }
}
</style>

{% schema %}
{
  "name": "Help Centre Contents",
  "class": "section--help-contents max-width",
  "settings": [],
  "max_blocks": 20,
  "blocks": [
    {
      "name": "Contents Card",
      "type": "card",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Title",
          "label": "Block Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Block Image"
        },
        {
          "type": "url",
          "id": "url",
          "info": "Link to FAQ Page",
          "label": "Block URL"
        }
      ]
    }
  ]
}
{% endschema %}
