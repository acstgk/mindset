{% assign widths = '600,750,900,1200,1920,2400,3000' | split: ',' %}

<pdp-carousel>
  {% for image in product.images %}
    {% unless forloop.index == 2 %}
      {% assign base_url = image | image_url: width: 1111 | remove: '1111' | prepend: request.origin %}
      {% assign img_widths = '' %}
      {% for width in widths %}
        {% assign img_widths = img_widths | append: base_url | append: width | append: ' ' | append: width | append: 'w, ' %}
      {% endfor %}
      {% assign img_widths = img_widths | remove_last: ',' %}

      <div class="pdp_slide splide__slide">
        <img
          width="{{ image.width }}"
          height="{{ image.height }}"
          alt="{{ image.alt }}"
          {% if forloop.first %}
            loading="eager"
            src="{{ base_url }}3000"
            srcset="{{ img_widths }}"
          {% else %}
            data-splide-lazy-srcset="{{ img_widths }}"
            data-splide-lazy="{{ base_url }}3000"
          {% endif %}
          sizes="200vw"
        >
      </div>
    {% endunless %}
  {% endfor %}
</pdp-carousel>

<aside id="product-details" class="max-width">
  <div class="" id="product-summary">
    {% render 'product-title' with product as 'product' %}
    {% render 'product-price' with product as 'product' %}
    {% unless product.type == 'Tracksuit Set' %}
      <div
        class="yotpo-widget-instance"
        data-yotpo-instance-id="1008278"
        data-yotpo-product-id="{{product.id}}"
        data-yotpo-cart-product-id="{{item.product.id}}"
        data-yotpo-section-id="{{template.name}}"
      ></div>
    {% endunless %}
  </div>
</aside>

<script type="module" src="{{ 'main-pdp.js' | asset_url }}"></script>

{% stylesheet %}
  .pdp-zoom-wrapper {
    position: absolute;
    inset: 0 0 0 0;
    z-index: 20;
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.3s ease, transform 0.3s ease;
    background-color: var(--c-off-white);

    & img {
      object-fit: cover;
    }
  }

  .pdp-zoom-btn.round-btn,
  .pdp-zoom-close-btn.round-btn {
    position: absolute;
    right: 2em;
    top: 2em;
  }

  pdp-carousel {
    max-height: calc(100vh - 88px);
    max-height: none;
    overflow: hidden;
    scroll-margin-top: 50px;
    transition: max-height 0.5s var(--overshoot-bezier);

    & .splide__list {
      width: 100%;

      & div {
        width: 100%;
        height: auto;
      }

      & img {
        width: 100%;
        height: auto;
        object-fit: cover;
      }
    }

    & .splide__pagination {
      position: absolute;
      bottom: 20px;
      left: 50%;
      translate: -50% 0;
      width: max-content;
      max-width: 90%;
      backdrop-filter: blur(2px);
      background-color: color-mix(in srgb, var(--c-black), transparent 90%);
      padding: 7px 14px;
      border-radius: 14px;
      gap: 7px;
      place-content: center;

      & li {
        display: grid;
        place-items: center;
      }

      & button {
        border-radius: 50%;
        height: 7px;
        width: 7px;
        background-color: color-mix(in srgb, var(--c-white), transparent 75%);
        padding: 0;

        &.is-active {
          background-color: var(--c-white);
        }
      }
    }
  }

  #product-details {
    & #product-summary {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      column-gap: 1em;

      & .yotpo-widget-instance {
        grid-area: 2 / 2 / 3 / 3;
        display: block;
        display: flex;
        justify-content: flex-end;
      }
    }

    & .Title {
      grid-area: 1 / 1 / 2 / 3;
      display: flex;
      justify-content: space-between;
    }

    & .Price--wrapper {
      grid-area: 2 / 1 / 3 / 2;
      & span {
        font-weight: 700;
      }
    }

    & .Price--wrapper,
    & h1.title {
      font-size: var(--txt-h4);
      gap: 0.4em;
      margin: 0;
      text-transform: none;
      letter-spacing: normal;
      font-family: var(--text-font-family);
      text-align: left;
      font-weight: 400;
    }

    & .Price--saving {
      margin: 0 auto 0 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Main Product Block",
  "class": "section--product_main",
  "limit": 1,
  "settings": []
}
{% endschema %}
