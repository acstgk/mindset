{% if section.settings.is_accent %}
  <div class="rich-content--wrapper" style="background-color:{{ section.settings.bg_color | default: '#f6f6f6' }}">
    {% if section.settings['background-image'] %}
      {{ section.settings['background-image'] | image_url: width: 2000 | image_tag: class: 'contrast-bg' }}
    {% endif %}
{% endif %}

<div class="max-width{% if section.settings.full_width %} align-{{ section.settings.alignment }}{% endif %}">
  {% if section.settings.grid_style == 'carousel' %}<div class="carousel">{% endif %}
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'rtf' %}
        <div class="rtf  {% if section.settings.grid_style == 'carousel' %}splide__slide{% endif %}">{{ block.settings.richtext_content }}</div>
      {% when 'quote' %}
        <blockquote
          {% unless block.settings.quote_author == blank %}
            data-quote-attribution="- {{  block.settings.quote_author }}"
          {% endunless %}
          class="
            splide__slide {% if section.settings['background-image'] %}
              contrast
            {% endif %}
          "
        >
          {{ block.settings.quote_text }}
        </blockquote>
      {% when 'images' %}
        <div class="image-grid splide__slide">
          {% if block.settings.image_1 %}
            {{ block.settings.image_1 | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'image-grid__item' }}
          {% endif %}
          {% if block.settings.image_2 %}
            {{ block.settings.image_2 | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'image-grid__item' }}
          {% endif %}
          {% if block.settings.image_3 %}
            {{ block.settings.image_3 | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'image-grid__item' }}
          {% endif %}
        </div>
      {% when 'video' %}
        {% if block.settings.hosted_video %}
          <custom-video-controls class="splide__slide">{{ block.settings.hosted_video | video_tag: image_size: '1270x' }}</custom-video-controls>
        {% else %}
          <div class="video-container splide__slide">
            <iframe
              src="https://www.youtube.com/embed/{{ block.settings.linked_video | split: "=" | last }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            >
            </iframe>
          </div>
        {% endif %}
      {% else %}
        {{ block.settings.custom_html }}
    {% endcase %}
  {% endfor %}
  {% if section.settings.grid_style == 'carousel' %}</div>{% endif %}
</div>

{% if section.settings.is_accent %}
  </div>
{% endif %}

{% if section.settings.grid_style == 'carousel' %}
  <script type="module">
    import { SplideUtil } from '{{ "SplideUtil.js" | asset_url }}';
    let thisslideCount = document.querySelector('#shopify-section-{{ section.id }} .carousel').querySelectorAll('.splide__slide').length;
    console.log('test :: ', document.querySelector('#shopify-section-{{ section.id }} .carousel'));
    console.log('test :: ', thisslideCount);
