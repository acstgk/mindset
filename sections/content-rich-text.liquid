<link rel="stylesheet" href="{{ 'rich-text.min.css' | asset_url }}">

{% if section.settings.is_accent %}
  <div class="rich-content--wrapper" style="background-color:{{ section.settings.bg_color | default: '#f6f6f6' }}">
    {% if section.settings['background-image'] %}
      {{ section.settings['background-image'] | image_url: width: 2000 | image_tag: class: 'contrast-bg' }}
    {% endif %}
{% endif %}

{% if section.settings.title %}
  <h2 class="{{ section.settings.heading_style }}">{{ section.settings.title }}</h2>
{% endif %}

<div class="max-width{% if section.settings.full_width %} align-{{ section.settings.alignment }}{% endif %}">
  {% if section.settings.grid_style == 'carousel' %}<div class="carousel">{% endif %}
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'rtf' %}
        <div class="rtf  {% if section.settings.grid_style == 'carousel' %}splide__slide{% endif %}">{{ block.settings.richtext_content }}</div>
      {% when 'quote' %}
        <blockquote
          {% unless block.settings.quote_author == blank %}
            data-quote-attribution="- {{  block.settings.quote_author }}"
          {% endunless %}
          class="
            {% if section.settings['background-image'] %}
              contrast
            {% endif %}
          "
        >
          {{ block.settings.quote_text }}
        </blockquote>
      {% when 'images' %}
        <div class="image-grid splide__slide">
          {% if block.settings.image_1 %}
            {{ block.settings.image_1 | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'image-grid__item' }}
          {% endif %}
          {% if block.settings.image_2 %}
            {{ block.settings.image_2 | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'image-grid__item' }}
          {% endif %}
          {% if block.settings.image_3 %}
            {{ block.settings.image_3 | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'image-grid__item' }}
          {% endif %}
        </div>
      {% when 'video' %}
        {% if block.settings.hosted_video %}
          <custom-video-controls class="splide__slide">{{ block.settings.hosted_video | video_tag: image_size: '1270x' }}</custom-video-controls>
        {% else %}
          <div class="video-container splide__slide">
            <iframe
              src="https://www.youtube.com/embed/{{ block.settings.linked_video | split: "=" | last }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            >
            </iframe>
          </div>
        {% endif %}
      {% when 'cta' %}
        <div
          class="cta-wrapper"
          style="text-align: center; padding: 30px 20px;display: flex;gap: 1rem;align-items: center;flex-direction: column;"
        >
          <a href="{{ block.settings.button_link }}" class="{{ section.settings.size }} button {%if block.settings.btn_color == true %}button-secondary{% else %}button-primary{% endif %}">
            {{ block.settings.btn_text }}
          </a>
          {% if block.settings.microcopy %}
            <p><i>{{ block.settings.microcopy }}</i></p>
          {% endif %}
        </div>
      {% else %}
        {{ block.settings.custom_html }}
    {% endcase %}
  {% endfor %}
  {% if section.settings.grid_style == 'carousel' %}</div>{% endif %}
</div>

{% if section.settings.is_accent %}
  </div>
{% endif %}

{% if section.settings.grid_style == 'carousel' %}
  <script type="module">
    import { SplideUtil } from '{{ "SplideUtil.js" | asset_url }}';
    document.addEventListener('DOMContentLoaded', () => {
      let thisslideCount = document.querySelector('#shopify-section-{{ section.id }} .carousel').querySelectorAll('.splide__slide').length;
      if (thisslideCount > 1) {
        SplideUtil.splideInit('#shopify-section-{{ section.id }} .carousel', {
          type: 'loop',
          pagination: true,
          arrows: false,
          speed: 1000,
        });
      }
    });
  </script>
{% endif %}

<style>
  #shopify-section-{{section.id}} {
    margin-block: {{ section.settings.v_padding }}px
  }
</style>
{% schema %}
{
  "name": "Editorial Content Block",
  "class": "section--rich-text",
  "settings": [
    {
      "type": "header",
      "content": "Section Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading Font Style",
      "options": [
        { "value": "", "label": "Normal" },
        { "value": "emphasis", "label": "Condensed Font" }
      ]
    },
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "range",
      "id": "v_padding",
      "label": "Padding",
      "min": -100,
      "max": 100,
      "step": 5,
      "default": 50,
      "info": "adds or removes space between this block and it's neighbouring blocks"
    },

    {
      "type": "checkbox",
      "id": "is_accent",
      "label": "Accent Background?",
      "info": "Use an accent background colour or image for this block",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "visible_if": "{{ section.settings.is_accent == true }}"
    },
    {
      "type": "image_picker",
      "id": "background-image",
      "label": "Background Image",
      "visible_if": "{{ section.settings.is_accent == true }}"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Use Full Width?",
      "info": "Choose whether to constain content to the narrow rich text width or use all available screen width",
      "default": false
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text Position",
      "options": [
        { "value": "left", "label": "Left Half" },
        { "value": "center", "label": "Full Width" },
        { "value": "right", "label": "Right Half" }
      ],
      "default": "right",
      "visible_if": "{{ section.settings.full_width == true }}"
    },
    {
      "type": "select",
      "id": "grid_style",
      "label": "Grid Style",
      "options": [
        { "label": "Stacked", "value": "standard" },
        { "label": "Carousel", "value": "carousel" }
      ],
      "default": "standard"
    }
  ],
  "blocks": [
    {
      "type": "rtf",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "richtext_content",
          "label": "Rich Text",
          "default": "<p>Add rich text content here.</p>"
        }
      ]
    },
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {
          "type": "text",
          "id": "quote_text",
          "label": "Quote Text",
          "default": "This is a sample quote."
        },
        {
          "type": "text",
          "id": "quote_author",
          "label": "Author",
          "default": "Author Name"
        }
      ]
    },
    {
      "type": "images",
      "name": "Images",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "hosted_video",
          "label": "Hosted Video"
        },
        {
          "type": "video_url",
          "id": "linked_video",
          "label": "Linked Youtube Video",
          "accept": ["youtube"]
        }
      ]
    },
    {
      "type": "cta",
      "name": "Call to Action",
      "settings": [
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "checkbox",
          "id": "btn_color",
          "label": "Use Secondary Button Style",
          "default": false
        },
        {
        "type": "text",
      "id": "microcopy",
      "label": "Sub Text"}
      ]
    },
    {
      "type": "html",
      "name": "Custom HTML",
      "settings": [
        {
          "type": "textarea",
          "id": "custom_html",
          "label": "HTML Code",
          "default": "<div>Your custom HTML here</div>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Content Block",
      "category": "Content"
    }
  ]
}
{% endschema %}
