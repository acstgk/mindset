      });
    }
  </script>
{% endif %}

<style>
  #shopify-section-{{section.id}} {
    margin-block: {{ section.settings.v_padding }}px
  }
  .rich-content--wrapper {
    display: grid;
    place-items: center;
    overflow: hidden;
    background-position: center;
    background-size: cover;
    position: relative;
    padding: 0;

    & .rtf>:first-child {
    margin-top: 2.4rem;
    }
    & .rtf>:last-child {
    margin-bottom: 2.4rem;
    }

    & > * {
      grid-area: 1 / 1;
      padding: 0;
    }

    & img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    & blockquote.contrast {
      color: white;
      {% comment %} text-shadow: 0 0 20px var(--c-dark-grey); {% endcomment %}
      background: rgb(25 25 25 / 0.1);
      backdrop-filter: blur(4px) brightness(0.8);
      margin-block: 4rem !important;
    }
  }

  .contrast-bg {
    position: absolute;
    inset: 0;
  }

    .rtf::before,
  .rtf::after,
  .rtf h3::before,
  .rtf h3::after {
  content: "";}

  @media screen and (width > 768px) {
    .align-right {
      padding-left: 35%;
      max-width: none;
    }

    .align-left {
      padding-right: 35%;
      max-width: none;
    }
  }
</style>
{% schema %}
{
  "name": "Editorial Content Block",
  "class": "section--rich-text",
  "settings": [
    {
      "type": "range",
      "id": "v_padding",
      "label": "Padding",
      "min": -100,
      "max": 100,
      "step": 5,
      "default": 50,
      "info": "adds or removes space between this block and it's neighbouring blocks"
    },
    {
      "type": "checkbox",
      "id": "is_accent",
      "label": "Accent Background?",
      "info": "Use an accent background colour or image for this block",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "visible_if": "{{ section.settings.is_accent == true }}"
    },
    {
      "type": "image_picker",
      "id": "background-image",
      "label": "Background Image",
      "visible_if": "{{ section.settings.is_accent == true }}"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Use Full Width?",
      "info": "Choose whether to constain content to the narrow rich text width or use all available screen width",
      "default": false
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text Position",
      "options": [
        { "value": "left", "label": "Left Half" },
        { "value": "center", "label": "Full Width" },
        { "value": "right", "label": "Right Half" }
      ],
      "default": "right",
      "visible_if": "{{ section.settings.full_width == true }}"
    },
    {
      "type": "select",
      "id": "grid_style",
      "label": "Grid Style",
      "options": [
        { "label": "Stacked", "value": "standard" },
        { "label": "Carousel", "value": "carousel" }
      ],
      "default": "standard"
    }
  ],
  "blocks": [
    {
      "type": "rtf",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "richtext_content",
          "label": "Rich Text",
          "default": "<p>Add rich text content here.</p>"
        }
      ]
    },
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {
          "type": "text",
          "id": "quote_text",
          "label": "Quote Text",
          "default": "This is a sample quote."
        },
        {
          "type": "text",
          "id": "quote_author",
          "label": "Author",
          "default": "Author Name"
        }
      ]
    },
    {
      "type": "images",
      "name": "Images",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "hosted_video",
          "label": "Hosted Video"
        },
        {
          "type": "video_url",
          "id": "linked_video",
          "label": "Linked Youtube Video",
          "accept": ["youtube"]
        }
      ]
    },
    {
      "type": "html",
      "name": "Custom HTML",
      "settings": [
        {
          "type": "textarea",
          "id": "custom_html",
          "label": "HTML Code",
          "default": "<div>Your custom HTML here</div>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Content Block",
      "category": "Content"
    }
  ]
}
{% endschema %}
