<link rel="stylesheet" href="{{ 'value-props.min.css' | asset_url }}">

{% for block in section.blocks %}
  {%- assign hide_announcement = false -%}
  {%- if localization.country.iso_code != 'GB' and block.settings.country_restriction == 'domestic_only' -%}
    {%- assign hide_announcement = true -%}
  {%- elsif localization.country.iso_code == 'GB' and block.settings.country_restriction == 'international_only' -%}
    {%- assign hide_announcement = true -%}
  {%- endif -%}

  {% unless hide_announcement %}
    {% if block.settings.block_link %}
      <a
        class="info-strip__block countdown-container"
        href="{{ block.settings.block_link.url }}"
        style="background:{{ block.settings.bg_colour }};color:{{block.settings.txt_colour}}"
        target="{{ block.settings.link_target }}"
      >
        {% unless block.settings.icon == 'noicon' %}{% render 'icon', icon: block.settings.icon %}{% endunless %}
        <p>
          {{- block.settings.title }}
        </p>
      </a>
    {% endif %}
  {% endunless %}
{% endfor %}


{% schema %}
{
  "name": "Announcement Block Banner",
  "class": "info-strip max-width",
  "limit": 1,
  "settings": [],
  "blocks": [
    {
      "type": "subtle-text-block",
      "name": "Announcement",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "will be displayed after countdown timer - if displayed."
        },
        {
          "type": "url",
          "id": "block_link",
          "label": "Link URL"
        },
        {
        "type":"select",
        "id":"link_target",
        "label":"Link Target",
        "options": [
          { "label": "Same Tab", "value": "_self" },
          { "label": "New Tab", "value": "_blank" }
        ],
        "default": "_self"
        },
        {
          "type": "color",
          "id": "bg_colour",
          "label": "Background Colour"
        },
        {
          "type": "select",
          "id": "txt_colour",
          "label": "Text Colour",
          "options": [
            { "label": "Black", "value": "#1b1b1b" },
            {
              "value": "white",
              "label": "White"
            }
          ]
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Show Icon",
          "options": [
            { "label": "No Icon", "value": "noicon" },
            { "value": "yt", "label": "Youtube" },
            { "value": "tt", "label": "Tiktok" },
            { "value": "check", "label": "Checkmark" },
            { "value": "close", "label": "Close (x)" },
            { "value": "tag", "label": "Sale Tag" },
            { "value": "truck", "label": "Truck" },
            { "value": "star", "label": "Star" },
            { "value": "return", "label": "Return" },
            { "value": "parcel", "label": "Parcel" },
            { "value": "giftcard", "label": "Gift Card" }
          ]
        },
        {
          "type": "select",
          "id": "country_restriction",
          "label": "Country Restriction",
          "info": "Choose which countries this announcement should display to",
          "default": "none",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "domestic_only",
              "label": "Domestic Only"
            },
            {
              "value": "international_only",
              "label": "International Only"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value Proposition Bar",
      "category": "General"
    }
  ]
}
{% endschema %}
