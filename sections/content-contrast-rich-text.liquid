<div class="accent-bg contrast-wrapper">
  {% if section.settings['background-image'] %}
    {{ section.settings['background-image'] | image_url: width: 2000 | image_tag: class: 'contrast-bg' }}
  {% endif %}
  <div
    class="rtf max-width {% if section.settings.full_width %} align-{{ section.settings.alignment }}{% endif %}"
    {% if section.settings.full_width %}
      style="max-width:none;"
    {% endif %}
  >
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'rtf' %}
          {{ block.settings.richtext_content }}
        {% when 'quote' %}
          <blockquote
            {% unless block.settings.quote_author == blank %}
              data-quote-attribution="- {{  block.settings.quote_author }}"
            {% endunless %}
          >
            {{ block.settings.quote_text }}
          </blockquote>
        {% when 'images' %}

        {% else %}

      {% endcase %}
    {% endfor %}
  </div>
</div>

<style>
  .contrast-wrapper {
    display: grid;
    place-items: center;
    overflow: hidden;
    background-position: center;
    background-size: cover;
    position: relative;
    padding: 0;

    & > * {
      grid-area: 1 / 1;
      padding: 0;
    }

    & img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    & blockquote {
      color: white;
      text-shadow: 0 0 20px var(--c-dark-grey);
      background: rgb(25 25 25 / 0.1);
      backdrop-filter: blur(4px);
      margin-block: 4rem !important;
    }
  }

  .contrast-bg {
    position: absolute;
    inset: 0;
  }

  @media screen and (width > 768px) {
    .align-right {
      padding-left: 35%;
    }

    .align-left {
      padding-right: 35%;
    }
  }
</style>
{% schema %}
{
  "name": "Rich Text Block",
  "class": "section--rich-text",
  "settings": [
    {
      "type": "image_picker",
      "id": "background-image",
      "label": "Background Image"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Width?",
      "info": "constain content to the narrow rich text width or use all available screen width",
      "default": true
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text Position",
      "options": [
        { "value": "left", "label": "Left Half" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right Half" }
      ],
      "default": "right",
      "visible_if": "{{ section.settings.full_width == true }}"
    }
  ],
  "blocks": [
    {
      "type": "rtf",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "richtext_content",
          "label": "Rich Text",
          "default": "<p>Add rich text content here.</p>"
        }
      ]
    },
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {
          "type": "text",
          "id": "quote_text",
          "label": "Quote Text",
          "default": "This is a sample quote."
        },
        {
          "type": "text",
          "id": "quote_author",
          "label": "Author",
          "default": "Author Name"
        }
      ]
    },
    {
      "type": "images",
      "name": "Images",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        }
      ]
    },
    {
      "type": "html",
      "name": "Custom HTML",
      "settings": [
        {
          "type": "textarea",
          "id": "custom_html",
          "label": "HTML Code",
          "default": "<div>Your custom HTML here</div>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contrast Content Blocks",
      "category": "Content"
    }
  ]
}
{% endschema %}
