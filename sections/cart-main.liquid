{% assign locale_uk = false %}
{% if request.locale.iso_code == 'en' %}
  {% assign locale_uk = true %}
{% endif %}

<div class="max-width">
  <div class="cart">
    <div class="cart-title">
      <h1>Your Bag</h1>
      {% if cart.item_count > 0 %}
        <a href="/checkout" class="checkout-button button button-primary"
          >Checkout - <span class="cart-total">{{ cart.total_price | money_without_trailing_zeros -}}</span>
        </a>
      {% endif %}
    </div>

    {% if cart.item_count == 0 %}
      <p class="center">Your Shopping Bag is empty.</p>
    {% else %}
      <div class="cart-header">
        <div>Product</div>
        <div>Quantity</div>
        <div>Total</div>
      </div>
      {% render 'cart-items' %}
      <div class="cart-footer">
        {% if locale_uk %}
          {% render 'free-delivery-information' %}
        {% endif %}
        <a href="/checkout" class="checkout-button button button-primary"
          >Checkout - <span class="cart-total">{{ cart.total_price | money_without_trailing_zeros -}}</span>
        </a>
        {% render 'payment-icons' %}
      </div>
    {% endif %}
  </div>

  {% unless locale_uk %}
    {% render 'delivery-estimator' %}
  {% endunless %}

  {% render 'cart-upsells' %}
  {% comment %} {% render 'trust-widget' with 'micro' %} {% endcomment %}

  <div class="usp">
    <div class="img">
      <img src="https://thegymking.com/cdn/shop/files/hisandhers.jpg?v=1761296439" alt="">
    </div>
    <div class="rtf">
      <h3 class="h4">Why Gym King?</h3>

      <p>With over 35,000 5* reviews on Trustpilot, there’s a reason our bestsellers are in demand.&nbsp;</p>
      <p>At Gym King, we focus on premium quality and great fitting designs with affordable prices. We want you to look and feel your best all day long.&nbsp;</p>
      <p><strong>Discover what our customers are saying about us:</strong></p>
      <p><em>“I absolutely love Gym King. Their products are outstanding quality.”</em></p>
      <p><em>“10/10. Great fit. Fast delivery. Amazing value. Can’t ask for more than that.”</em></p>
      <p><em>“Love everything about Gym King. The material, the fit, fast delivery, easy returns.”&nbsp;</em></p>
      <a href="/pages/about-us" class="button button-primary">More about us</a>
    </div>
  </div>
</div>

<div class="accent-bg">
  <div class="max-width">
    <h3 class="h4 no-block-margin" style="margin-top: 4rem">Forgotten something?</h3>
    {% render 'dead-end' %}
  </div>
</div>

<link rel="stylesheet" href="{{ 'cart.min.css' | asset_url }}">
{% schema %}
{
  "name": "Main Cart",
  "class": "section--cart_content",
  "limit": 1,
  "settings": []
}
{% endschema %}
