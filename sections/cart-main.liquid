{% assign locale_uk = false %}
{% if request.locale.iso_code == 'en' %}
  {% assign locale_uk = true %}
{% endif %}

{% assign cart_empty = true %}
{% if cart.item_count > 0 %}
  {% assign cart_empty = false %}
{% endif %}

<div class="max-width">
  <div class="cart">
    <div class="cart-title">
      <h1>Your Bag</h1>
      {% unless cart_empty %}
        <a href="/checkout" class="checkout-button button button-primary" id="main-cart--button"
          >Checkout - <span class="cart-total">{{ cart.total_price | money_without_trailing_zeros -}}</span>
        </a>
        <p class="info">
          {% render 'icon', icon: 'info' -%}
          <b>Your items aren't reserved,</b> checkout to ensure you don't miss out
        </p>
      {% endunless %}
    </div>

    {% if cart_empty %}
      <div class="cart--empty">
        <p class="center">Your Shopping Bag is empty.</p>
        {% render 'dead-end' %}
      </div>
    {% else %}
      <div class="cart-header">
        <div>Product</div>
        <div>Quantity</div>
        <div>Total</div>
      </div>
      {% render 'cart-items' %}
      <div class="cart-footer">
        {% if locale_uk %}
          {% render 'free-delivery-information' %}
        {% endif %}
        <a href="/checkout" class="checkout-button button button-primary"
          >Checkout - <span class="cart-total">{{ cart.total_price | money_without_trailing_zeros -}}</span>
        </a>
        {% render 'payment-icons' %}
      </div>
    {% endif %}
  </div>

  {% unless locale_uk %}
    {% render 'delivery-estimator' %}
  {% endunless %}

  {% render 'cart-upsells' %}
  {% comment %} {% render 'trust-widget' with 'micro' %} {% endcomment %}

  <div class="usp">
    <div class="img">
      {{ section.settings.about_img | image_url: width: '700' | image_tag }}
    </div>
    <div class="rtf">
      <h3 class="h4">Why Gym King?</h3>
      {{ section.settings.about_text }}
      <a href="/pages/about-us" class="button button-primary">More about us</a>
    </div>
  </div>
</div>

{% render 'as-seen-in' %}

{% unless cart_empty %}
  <div class="accent-bg">
    <div class="max-width">
      <h3 class="h4 no-block-margin" style="margin-top: 4rem">Forgotten something?</h3>
      {% render 'dead-end' %}
    </div>
  </div>
{% endunless %}

<link rel="stylesheet" href="{{ 'cart.min.css' | asset_url }}">

<script>
  document.addEventListener('cart:itemsAdded', () => {
    getCart();
    document.body.classList.remove('no-scroll');
  });
  document.addEventListener('cart:loaded', () => {
    console.log('cart:', Cart.cart.item_count);
    if (Cart.cart.item_count < 1) {
      getCart();
    }
  });

  function getCart() {
    fetch('/cart')
      .then((response) => response.text())
      .then((html) => {
        // Parse the fetched HTML into a DOM
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');

        // Select the new cart element from the fetched page
        const newCart = doc.querySelector('.cart');
        const currentCart = document.querySelector('.cart');

        if (newCart && currentCart) {
          // Replace the existing cart with the new one
          currentCart.replaceWith(newCart);
        } else {
          console.error('Cart element not found in current or fetched document.');
        }
      })
      .catch((err) => console.error('Error fetching /cart:', err));
  }
</script>

{% schema %}
{
  "name": "Main Cart",
  "class": "section--cart_content",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "about_img",
      "label": "About Us Image"
    },
    {
      "type": "richtext",
      "id": "about_text",
      "label": "About Us Text"
    }
  ]
}
{% endschema %}
