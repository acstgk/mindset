{% comment %}
  Dynamic 'Complete the Look' section.
  1. Shows 'as-seen-in' if cart is empty.
  2. Pulls complementary products from Shopify Search & Discovery app or manual 'productlink:' tags.
  3. Filters recommendations based on a global inventory buffer.
{% endcomment %}

{% assign all_tags = product.tags | join: ',' %}

{% comment %} Show fallback section if no items are in the cart {% endcomment %}
{% if cart.item_count == 0 %}
  {% render 'as-seen-in' %}
{% endif %}

{% comment %} Identify which variants are in stock and above the product buffer threshold {% endcomment %}
{% assign instock_variants = '' %}
{% for variant in product.variants %}
  {% if variant.available and variant.inventory_quantity > settings.product_buffer %}
    {% assign instock_variants = instock_variants | append: variant.title | append: '+' %}
  {% endif %}
{% endfor %}

{% comment %} Check for recommendations: priority given to Search & Discovery metafields {% endcomment %}
{% if all_tags contains 'productlink:' or product.metafields['shopify--discovery--product_recommendation'].complementary_products.list? %}
  <link rel="stylesheet" href="{{ 'complete-the-look.min.css' | asset_url }}">
  {% assign instockcount = 0 %}
  {% assign product_handles = '' %}
  {% if product.metafields['shopify--discovery--product_recommendation'].complementary_products.list? %}
    {% comment %} Iterate through Discovery App recommendations {% endcomment %}
    {% for product in product.metafields['shopify--discovery--product_recommendation'].complementary_products.value %}
      {% comment %} Loop through the variants validate display {% endcomment %}

      {% assign inventory_quantity = 0 %}
      {% for variant in product.variants %}
        {% assign inventory_quantity = inventory_quantity | plus: variant.inventory_quantity %}
      {% endfor %}

      {% comment %} Only add to list if total product stock is above the buffer {% endcomment %}
      {% if product.available and inventory_quantity > settings.product_buffer %}
        {% assign product_handles = product_handles | append: '+' | append: product.handle %}
        {% assign instockcount = instockcount | plus: 1 %}
      {% endif %}
    {% endfor %}
  {% else %}
    {% comment %} Fallback: Manual 'productlink:ID+ID' tags {% endcomment %}
    {% assign tag = product.tags | where: 'productlink:' | first %}
    {% assign linked_products = tag | remove: 'productlink:' | split: '+' %}
    {% if linked_products.size >= 1 %}
      {% for linked_product in linked_products %}
        {% for collection in product.collections %}
          {% paginate collection.products by 1000 %}
            {% for product in collection.products %}
              {% assign linked_product_id = linked_product | plus: 0 %}
              {% if product.id == linked_product_id and product.available %}
                {% comment %} Aggregate total stock for the manually linked product {% endcomment %}
                {% assign inventory_quantity = 0 %}
                {% assign enough_stock = false %}
                {% assign total_variants_available = 0 %}
                {% assign total_variants = 0 %}
                {% for variant in product.variants %}
                  {% assign inventory_quantity = inventory_quantity | plus: variant.inventory_quantity %}
                  {% if variant.inventory_quantity > settings.product_buffer %}
                    {% assign total_variants_available = total_variants_available | plus: 1 %}
                    {% if instock_variants contains variant.title %}
                      {% assign enough_stock = true %}
                    {% endif %}
                  {% endif %}
                  {% if forloop.last %}
                    {% assign total_variants = total_variants_available | times: 100 | divided_by: forloop.index %}
                  {% endif %}
                {% endfor %}
                {% if enough_stock == false and total_variants > 49 %}
                  {% assign enough_stock = true %}
                {% endif %}

                {% unless product_handles contains product.handle or inventory_quantity <= settings.product_buffer or enough_stock == false %}
                  {% assign product_handles = product_handles | append: '+' | append: product.handle %}
                  {% assign instockcount = instockcount | plus: 1 %}
                {% endunless %}
              {% endif %}
            {% endfor %}
          {% endpaginate %}
        {% endfor %}
      {% endfor %}
    {% endif %}
  {% endif %}

  {% comment %} Render the section if we have valid, in-stock recommendations {% endcomment %}
  {% if instockcount > 0 and product.type != 'Tracksuit Set' %}
    <div class="accent-bg">
      <h2 class="h1">COMPLETE THE LOOK</h2>
      {% comment %} Desktop Carousel View {% endcomment %}
      <productcard-carousel id="completethelook">
        {% assign product_handles = product_handles | remove_first: '+' | split: '+' %}
        {% for handle in product_handles %}
          {%- render 'product-card' with all_products[handle] as product, class: 'splide__slide' -%}
        {% endfor %}
      </productcard-carousel>
      {% comment %} Mobile Stacked View with ATC functionality {% endcomment %}
      <div id="completethelook--mobile" class="max-width">
        {% for handle in product_handles %}
          {% assign handle_product = all_products[handle] %}
          <div data-price="{{ handle_product.price }}" data-title="{{ handle_product.title }}" data-gender="{{ handle_product.gender }}" data-id="{{ handle_product.id }}" class="completethelook--product">
            <a href="{{ handle_product.url }}" alt="{{ handle_product.title }}">
              {{- handle_product.featured_image | image_url: width: 3250 | image_tag: class: 'completethelook--product-image', widths: '300, 450, 600, 750, 900, 1200, 1800' -}}
            </a>
            <div class="completethelook--product--content">
              <div class="recommendations-pricecontainer">
                {% render 'product-title' with handle_product as product %}
                {% render 'product-price' with handle_product as product %}
              </div>
              <div id="options-{{handle_product.id}}" class="product-options">
                <form id="atc_form_{{handle_product.id}}" class="ctl-atc-form" method="post" action="{{ routes.cart_add_url }}">
                  <label for="atc{{handle_product.id}}" class="visually-hidden">Select Size</label>
                  <select name="id" id="atc{{handle_product.id}}" data-productid="{{handle_product.id}}" class="button product-select" required>
                    {% if handle_product.variants.size > 1 %}
                      <option value="" disabled selected>Select Size</option>
                    {% endif %}
                    {% for variant in handle_product.variants %}
                      {% if variant.inventory_quantity > settings.product_buffer or variant.inventory_policy == 'continue' %}
                        <option
                          {% comment %} START Global-e VAT tag {% endcomment %}
                          {% if variant.taxable == false %}
                            data-product-vat="0"
                          {% endif %}
                          {% if variant.metafields.GlobalE.product_meta != blank %}
                            data-product-meta="{{variant.metafields.GlobalE.product_meta | json | escape}}"
                          {% endif %}
                          {% comment %}END Global-e VAT tag {% endcomment %}
                          value="{{ variant.id }}"
                          data-price="{{variant.price | money_without_trailing_zeros}}"
                        >
                          {% if handle_product.variants.size == 1 %}One Size{% else %}{{ variant.title }}{% endif %}
                        </option>
                      {% else %}
                        <option class="disabled" disabled>{{ variant.title }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="button button-primary atc-btn-contents">Add to Bag</button>
                </form>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
{% endif %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.ctl-atc-form').forEach(form => {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        const variantId = this.querySelector('select[name="id"]').value;

        if (!variantId) {
          alert('Please select a size');
          return;
        }

        submitBtn.innerHTML = '<div class="loader" style="--height:1em;z-index:1;backdrop-filter: invert(1)"></div>';
        submitBtn.setAttribute('disabled', 'disabled');

        Cart.addItems([{ id: variantId, quantity: 1 }])
          .then(() => {
            submitBtn.innerHTML = originalText;
            submitBtn.removeAttribute('disabled');
          })
          .catch((err) => {
            submitBtn.innerHTML = originalText;
            submitBtn.removeAttribute('disabled');
            console.error('ATC Error:', err);
          });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Complete the Look",
  "class": "section--complete-the-look",
  "settings": []
}
{% endschema %}
