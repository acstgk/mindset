<link rel="stylesheet" href="{{ 'customer.min.css' | asset_url }}">

{% comment %} <img src="https://cdn.shopify.com/s/files/1/1659/8997/files/Gym_King_Logo-whitebg.png?v=1753428715" alt="" width="80" height="80" class="roundel"> {% endcomment %}

{%- form 'activate_customer_password', name: 'activate', class: 'Form Form--spacingTight', id: 'activate_customer_password' -%}
  <h1 class="Form__Title Heading u-h1">{{ 'customer.activate_account.title' | t }}</h1>
  {% comment %} <p>{{ 'customer.activate_account.description' | t }}</p> {% endcomment %}

  {%- if form.errors -%}
    <div class="warnining">
      <ul class="Alert__ErrorList">
        {%- for field in form.errors -%}
          {%- if field == 'form' -%}
            <li class="Alert__ErrorItem">{{ form.errors.messages[field] }}</li>
          {%- else -%}
            <li class="Alert__ErrorItem">
              <strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}

  <div class="Form__Item">
    <input type="password" class="Form__Input" name="customer[password]" aria-label="{{ 'customer.activate_account.password' | t }}" placeholder="{{ 'customer.activate_account.password' | t }}" required="required">
    <label>{{ 'customer.activate_account.password' | t }}</label>
  </div>

  <div class="Form__Item">
    <input
      type="password"
      class="Form__Input"
      name="customer[password_confirmation]"
      aria-label="{{ 'customer.activate_account.password_confirmation' | t }}"
      placeholder="{{ 'customer.activate_account.password_confirmation' | t }}"
      required="required"
    >
    <label>{{ 'customer.activate_account.password_confirmation' | t }}</label>
  </div>

  <button type="submit" class="button button-primary button-full">{{ 'customer.activate_account.submit' | t }}</button>
  <button type="submit" class="button button-primary button-full">{{ 'customer.activate_account.decline' | t }}</button>
{%- endform -%}

{% schema %}
{
  "name": "Main Activate",
  "class": "section--main-active max-width",
  "settings": []
}
{% endschema %}
