      "type": "content-rich-text",
      "blocks": {
        "quote_yRzTYp": {
          "type": "quote",
          "settings": {
            "quote_text": "I’ve always believed that the human body is more powerful than we think—it’s the mind that has to catch up. My journey has been about exploring that connection of mind over matter. whether it’s swimming around Britain or running a marathon with a tree on my back. The partnership with Gym King is a natural fit. They represent resilience, strength and Mindset—three things I live by.",
            "quote_author": "Ross Edgley, Gym King Ambassador"
          }
        }
      },
