      "blocks": {
        "quote_tfyHRt": {
          "type": "quote",
          "settings": {
            "quote_text": "In my early twenties, I faced mental health challenges and battled depression. Instead of succumbing, I delved into mental health awareness, spirituality, cognitive performance, and physical fitness. My quest took me around the world, from rigorous four-week fight camps in Thailand to braving the frosty peaks of Poland with the legendary Wim Hof.",
            "quote_author": "Luke Powell, Gym King Ambassador"
          }
        }
      },
