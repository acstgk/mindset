        "quote_NdQVaq": {
          "type": "quote",
          "settings": {
            "quote_text": "Muay Thai has been my life since I was a kid. I’ve fought all over the world and faced the toughest opponents. The journey has taught me more than just how to fight—it’s taught me about discipline, hard work, and mental strength. Gym King shares those values, and I’m proud to represent a brand that supports athletes who give it their all.",
            "quote_author": "Liam Harrison, Gym King Ambassador"
          }
        }
      },
