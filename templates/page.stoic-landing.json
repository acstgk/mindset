            "custom_html": "<div class=\"two-col rtf\">\n      <span>\n        <p><b>Men’s Singles</b></p>\n        <ul>\n          <li>Registration: 8:15AM – 8:45AM</li>\n          <li>Circuit: 9:00AM – 10:30AM</li>\n        </ul>\n      </span>\n      <span>\n        <p><b>Women’s Singles</b></p>\n        <ul>\n          <li>Registration: 10:00AM – 10:30AM</li>\n          <li>Circuit: 11:00AM – 12:30PM</li>\n        </ul>\n      </span>\n      <span>\n        <p><b>Men’s</b><b> Doubles</b></p>\n        <ul>\n          <li>Registration: 12:00PM – 12:30PM</li>\n          <li>Circuit: 1:00PM – 2:30PM</li>\n        </ul>\n      </span>\n      <span>\n        <p><b>Women’s Doubles</b></p>\n        <ul>\n          <li>Registration: 2:00PM – 2:30PM</li>\n          <li>Circuit: 3:00PM – 4:30PM</li>\n        </ul>\n      </span>\n    </div>"
