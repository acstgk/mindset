          "settings": {
            "title": "Who are Klarna?",
            "htmlContent": "",
            "content": "<p>Klarna is a Swedish payment service provider that takes end-to-end responsibility for your payment. Klarna is the provider of smooth payments to more than 200,000 online stores. Over 85 million consumers worldwide have trusted Klarna to securely handle their payments.</p>"
          }
        },
        "card_6f9Lf9": {
          "type": "card",
          "settings": {
            "title": "How does Klarna Work?",
            "htmlContent": "",
            "content": "<p>Just shop on Gym King and check out as normal. At checkout, then choose the Klarna payment method. You will know if you are approved in seconds and once approved you will get an email confirmation from Klarna.</p>"
          }
        },
        "card_zT3zMH": {
          "type": "card",
          "settings": {
            "title": "Where can I use Klarna?",
            "htmlContent": "",
            "content": "<p>Just shop on Gym King and check out as normal. At checkout, then choose the Klarna payment method. You will know if you are approved in seconds and once approved you will get an email confirmation from Klarna.</p>"
          }
        },
