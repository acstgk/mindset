  {
    "name": "Countdown",
    "settings": [
      {
        "type": "text",
        "id": "countdown-date",
        "info": "MM/DD/YY 11:11 AM",
        "label": "Enter End Date"
      },
      {
        "type": "header",
        "content": "Product Card Settings"
      },
      {
        "type": "checkbox",
        "id": "countdown-product-check",
        "label": "Enable Product Card Countdown",
        "default": false
      },
      {
        "type": "text",
        "id": "countdown-title",
        "info": "Countdown Title",
        "label": "Enter Title"
      },
      {
        "type": "text",
        "id": "countdown-tag",
        "info": "Countdown Tag",
        "label": "Enter Tag"
      },
      {
        "type": "image_picker",
        "id": "countdown-decal",
        "info": "recommended: 950px x 500px full bleed image with transparent background.",
        "label": "Countdown Decal Image"
      },
      {
        "type": "checkbox",
        "id": "decal-check",
        "label": "Force Decal On",
        "info": "Displays the chosen decal ALL THE TIME - turn off if you want the decal to be controlled by the countdown timer.",
        "default": false
      },
      {
        "type": "header",
        "content": "Announcement Settings"
      },
      {
        "type": "text",
        "id": "countdown-announcement-text",
        "label": "Announcement Countdown Text",
        "info": "text displayed inline before countdown",
        "default": "Ends in"
      }
    ]
  },
