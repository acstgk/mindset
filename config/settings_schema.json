  {
    "name": "Product Buffer",
    "settings": [
      {
        "type": "range",
        "id": "product_buffer",
        "min": 0,
        "max": 20,
        "step": 1,
        "label": "Product Buffer",
        "default": 0,
        "info": "Only products with a total inventory move than this value will be displayed in carousels and search."
      }
    ]
  },
  {
    "name": "General Settings",
    "settings": [
      {
        "type": "color",
        "id": "sale_colour",
        "label": "Sale Colour",
        "default": "#811922"
      },
      {
        "type": "header",
        "content": "Favicon"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Main/Light Theme Icon",
        "info": "required* - 96 x 96px .png recommended"
      },
      {
        "type": "image_picker",
        "id": "alt_favicon",
        "label": "Alternate/Dark Theme Icon",
        "info": "optional* - 96 x 96px .png recommended"
      },
      {
        "type": "header",
        "content": "Default Meta Description"
      },
      {
        "type": "textarea",
        "id": "default-meta-description",
        "label": "Default Meta Description",
        "info": "shown if page meta description is missing for",
        "default": "Discover gym clothes, loungewear, and activewear designed for both performance and lifestyle. From premium tracksuits, fleece, and borg layers to high-performance gym wear and athleisure staples, every piece is built to move with you, whether you’re training hard, unwinding in comfort, or taking on the everyday. Rooted in resilience, ambition, and community, this is more than just workout clothing; it’s a mindset."
      },
      {
        "type": "header",
        "content": "Product Decals"
      },
      {
        "type": "checkbox",
        "id": "showMiniDecal",
        "label": "Show Mini Me Product Decals?",
        "default": false
      },
      {
        "type": "text",
        "id": "mini_tag",
        "label": "Mini Me Product Tag",
        "default": "Mini Me",
        "visible_if": "{{ settings.showMiniDecal == true }}"
      },
      {
        "type": "checkbox",
        "id": "decal_new",
        "label": "Show New Product Decals?",
        "default": true
      },
      {
        "type": "range",
        "id": "decal_new_days",
        "label": "New Product Days",
        "info": "For how many days should a product be classed as new?",
        "default": 28,
        "min": 1,
        "max": 100,
        "step": 1,
        "visible_if": "{{ settings.decal_new == true }}"
      }
    ]
  }
]