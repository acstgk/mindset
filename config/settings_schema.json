  {
    "name": "Delivery Information",
    "settings": [
      {
        "type": "header",
        "content": "Delivery Settings",
        "info": "These settings will be used to calculate the delivery ETA on site."
      },
      {
        "type": "range",
        "id": "transit_time",
        "label": "Expected Transit Time (in days)",
        "default": 2,
        "min": 0,
        "max": 14,
        "info": "set the longest expected transit time for the fastest current service"
      },
      {
        "type": "text",
        "label": "Fastest Delivery Service Name",
        "id": "fastest_delivery_service_name",
        "default": "UK Express Delivery"
      },
      {
        "type": "checkbox",
        "id": "enable_weekend_delivery",
        "label": "Enable Weekend Delivery?",
        "default": false,
        "info": "If enabled, weekends will be treated as possible delivery days."
      },
      {
        "type": "checkbox",
        "id": "enable_saturday_delivery",
        "label": "Is saturday Delivery available?",
        "default": true,
        "info": "If enabled, Saturday delivery service will offered on Thurs/Fri."
      },
      {
        "type": "header",
        "content": "Main Free Delivery Threshold",
        "info": "Set the main free delivery threshold for the site."
      },
      {
        "type": "number",
        "id": "delivery-threshold-value",
        "label": "Delivery Threshold Value",
        "info": "Set the value for free delivery in pence.",
        "default": 7500
      },
      {
        "type": "text",
        "id": "delivery-threshold-name",
        "label": "Delivery Service Name",
        "default": "UK Standard Delivery"
      },
      {
        "type": "header",
        "content": "Secondary Free Delivery Threshold",
        "info": "Activate and set a second free delivery threshold for the site."
      },
      {
        "type": "checkbox",
        "id": "show-delivery-threshold2",
        "label": "Show 2nd Delivery Threshold",
        "default": true
      },
      {
        "type": "number",
        "id": "delivery-threshold2-value",
        "label": "Delivery Threshold Value",
        "info": "Set the value for free delivery in pence.",
        "default": 12500,
        "visible_if": "{{ settings.show-delivery-threshold2 == true }}"
      },
      {
        "type": "text",
        "id": "delivery-threshold2-name",
        "label": "Delivery Service Name",
        "default": "UK Express Delivery",
        "visible_if": "{{ settings.show-delivery-threshold2 == true }}"
      },
      {
        "type": "header",
        "content": "Returns",
      },
      {
        "type": "number",
        "id": "return_fee",
        "label": "Domestic (UK) Return Fee Amount",
        "info": "enter the fee in pence",
        "default": 349
      }
    ]
  },
