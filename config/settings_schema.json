  {
    "name": "Countdown",
    "settings": [
      {
        "type": "text",
        "id": "countdown-date",
        "info": "MM/DD/YY 11:11 AM",
        "label": "Enter Date"
      },
      {
        "type": "header",
        "content": "Product Card Settings"
      },
      {
        "type": "checkbox",
        "id": "countdown-product-check",
        "label": "Enable Product Card Countdown",
        "default": false
      },
      {
        "type": "text",
        "id": "countdown-title",
        "info": "Countdown Title",
        "label": "Enter Title"
      },
      {
        "type": "text",
        "id": "countdown-tag",
        "info": "Countdown Tag",
        "label": "Enter Tag"
      },
      {
        "type": "image_picker",
        "id": "countdown-decal",
        "info": "Image should be 746px x 200px, with a transparent bg if required.",
        "label": "Countdown Decal Image"
      },
      {
        "type": "checkbox",
        "id": "decal-check",
        "label": "Force Decal On",
        "info": "Displays the chosen decal ALL THE TIME - turn off if you want the decal to be controlled by the countdown timer.",
        "default": false
      },
      {
        "type": "header",
        "content": "Announcement Settings"
      },
      {
        "type": "checkbox",
        "id": "countdown-announcement-check",
        "label": "Enable Announcement Countdown",
        "info": "Will display first on countdown",
        "default": false
      },
      {
        "type": "text",
        "id": "countdown-announcement-title",
        "label": "Announcement Countdown Title"
      },
      {
        "type": "text",
        "id": "countdown-announcement-text",
        "label": "Announcement Countdown Text"
      },
      {
        "type": "url",
        "id": "countdown-announcement-url",
        "label": "Announcement Countdown URL"
      }
    ]
  },
