[
  {
    "name": "theme_info",
    "theme_name": "GK Mindset",
    "theme_author": "Adam Snape",
    "theme_version": "0.0.1",
    "theme_documentation_url": "https://gymking.com/",
    "theme_support_url": "https://gymking.com"
